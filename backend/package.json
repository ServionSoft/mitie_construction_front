{
  "name": "construction-erp-backend",
  "version": "1.0.0",
  "description": "Backend API for Construction ERP",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build --prefix server",
    "start": "npm run start:prod --prefix server",
    "dev": "npm run start:dev --prefix server",
    "dev:express": "nodemon --watch src --ext ts --exec ts-node src/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "mysql2": "^3.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}

